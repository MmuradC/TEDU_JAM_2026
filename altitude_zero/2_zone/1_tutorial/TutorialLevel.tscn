[sub_resource type="Shader" id="Shader_lens_blur"]
code = "shader_type canvas_item;
uniform sampler2D screen_texture : hint_screen_texture, filter_linear_mipmap;
uniform float blur_amount : hint_range(0.0, 5.0) = 2.0;
uniform vec2 lens_size = vec2(0.6, 0.6);

void fragment() {
	vec2 uv = SCREEN_UV;
	vec2 center_uv = (UV - 0.5);
	bool inside = abs(center_uv.x) < lens_size.x/2.0 && abs(center_uv.y) < lens_size.y/2.0;
	
	if (inside) {
		COLOR = texture(screen_texture, uv);
	} else {
		COLOR = textureLod(screen_texture, uv, blur_amount);
		COLOR.rgb *= 0.5;
	}
}"

